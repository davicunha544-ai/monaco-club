// Monaco Club — schema do banco.
// Postgres (Neon) em produção e em dev. Configure DATABASE_URL no .env
// com a connection string do Neon (ver README / .env.example).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  nome            String
  email           String    @unique
  passwordHash    String
  role            String    @default("cliente")
  aceitouTermosEm DateTime?
  createdAt       DateTime  @default(now())

  addresses Address[]
  orders    Order[]
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome        String
  cpf         String?
  cep         String
  logradouro  String
  numero      String
  complemento String?
  bairro      String
  cidade      String
  estado      String
  padrao      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // pendente -> pago -> enviado -> entregue / cancelado
  status          String   @default("pendente")
  subtotal        Float
  descontoPercent Int      @default(0)
  descontoValor   Float    @default(0)
  freteNome       String?
  freteValor      Float    @default(0)
  total           Float
  enderecoResumo  String?
  cpf             String?
  // pagamento (abstração; gateway real depois)
  paymentProvider String?
  paymentStatus   String   @default("aguardando")
  paymentRef      String?
  createdAt       DateTime @default(now())

  items OrderItem[]
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productSlug String
  nome        String
  preco       Float
  tamanho     String
  quantidade  Int
  imagem      String
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  nome        String
  descricao   String   @default("")
  preco       Float
  precoAntigo Float?
  imagem      String
  cores       String? // CSV: "Preto,Branco"
  tamanhos    String   @default("") // CSV: "P,M,G,GG"
  genero      String // "masculino" | "feminino"
  categoria   String
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
}
