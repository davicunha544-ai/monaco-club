# Copie para .env e preencha.

# Banco de dados.
# Local (SQLite):
DATABASE_URL="file:./dev.db"
# Produção (Postgres — Neon/Vercel/Supabase): troque o provider em prisma/schema.prisma
# para "postgresql" e use algo como:
# DATABASE_URL="postgresql://USER:PASS@HOST/DB?sslmode=require"

# Segredo do Auth.js. Gere com: openssl rand -base64 32
AUTH_SECRET="troque-por-um-segredo-aleatorio"

# E-mail (opcional). Sem isso, os e-mails são apenas registrados no log (dev).
# Crie uma conta em https://resend.com e gere a API key.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Monaco Club <no-reply@seudominio.com>"
