# Copie para .env e preencha.

# ── Banco de dados (Postgres / Neon) ────────────────────────────────────────
# Pegue a connection string no painel do Neon (ou na integração da Vercel).
# Ex.: postgresql://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL="postgresql://USER:PASS@HOST/DB?sslmode=require"

# ── Auth.js ─────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET="troque-por-um-segredo-aleatorio"
# Em produção atrás de proxy/HTTPS (Vercel já resolve, mas deixe ligado):
AUTH_TRUST_HOST="true"
# Opcional — URL pública do site (OG/e-mails). Na Vercel pode deixar em branco.
# NEXT_PUBLIC_SITE_URL="https://seudominio.com"

# ── Upload de imagens (Vercel Blob) ─────────────────────────────────────────
# Sem esta variável, o upload grava em public/uploads (só dev local).
# Crie um Blob Store na Vercel (Storage) — a env é injetada automaticamente lá.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── E-mail (opcional) ───────────────────────────────────────────────────────
# Sem isso, os e-mails só aparecem no log. Crie conta em https://resend.com.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Monaco Club <no-reply@seudominio.com>"
